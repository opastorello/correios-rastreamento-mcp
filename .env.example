# ── Auth ────────────────────────────────────────────────────
# Se vazio, servidor roda sem autenticação
API_TOKEN=

# ── Ambiente ────────────────────────────────────────────────
# development → /docs, /redoc, /openapi.json, /health ficam abertos sem token
# production  → apenas / fica acessível sem token
ENV=development

# ── Correios scraping ────────────────────────────────────────
HTTP_TIMEOUT=30
CAPTCHA_TIMEOUT=15
MAX_RETRIES=4
MAX_CONCURRENT=10

# ── Rate limits (formato: N/second | N/minute | N/hour) ──────
RATE_LIMIT_OBJETO=20/minute
RATE_LIMIT_MULTIPLOS=10/minute

# ── Captcha model ────────────────────────────────────────────
# Vazio = usa o modelo padrão em app/captcha/captcha_model.pt
CAPTCHA_MODEL_PATH=

# ── Histórico ────────────────────────────────────────────────
# Dias de retenção dos dados. 0 = sem limite
HISTORY_RETENTION_DAYS=90
# Timezone para timestamps do histórico
APP_TIMEZONE=America/Sao_Paulo
